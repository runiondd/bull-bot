# Copy this file to `.env` and fill in your API keys.
# The `.env` file is gitignored and never committed.

# Polygon.io — https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_key_here

# Unusual Whales — https://unusualwhales.com/settings/api
UNUSUAL_WHALES_API_KEY=your_uw_key_here

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: notification webhook (Slack/Discord) for daily reports
NOTIFY_WEBHOOK_URL=

# Timezone for scheduling (default: America/New_York)
TIMEZONE=America/New_York
